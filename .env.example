# Claude API
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Gmail SMTP (App Password)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=
EMAIL_RECIPIENT=your_gmail@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# 필터 (2~3일 연속 상승)
MIN_CONSECUTIVE_UP_DAYS=2
MAX_CONSECUTIVE_UP_DAYS=3

# 스케줄 (분, KST)
PRICE_INTERVAL_MIN=60
NEWS_INTERVAL_MIN=5
TRACK_HOUR_KST=0
TRACK_MINUTE_KST=5

# RSS 피드
COINNESS_RSS=https://coinness.live/rss
TOKENPOST_RSS=https://www.tokenpost.kr/rss
NEWS_HTTP_TIMEOUT=10

# 종료 기준
TRAILING_DROP_THRESHOLD=0.07
CONSECUTIVE_RED_DAYS=2

# 운영
DRY_RUN=false
LOG_LEVEL=INFO
TZ=Asia/Seoul
